# CI/CD
CI_ENVIRONMENT = development

# app
app.baseURL = 'http://localhost:8080'
app.forceGlobalSecureRequests = false
app.sessionDriver = 'CodeIgniter\Session\Handlers\FileHandler'
app.sessionCookieName = 'ci_session'
app.sessionExpiration = 7200
app.sessionSavePath = null
app.sessionMatchIP = false
app.sessionTimeToUpdate = 300
app.sessionRegenerateDestroy = false
app.CSPEnabled = false

# database.default
database.default.hostname = localhost
database.default.database = rh
database.default.username = 
database.default.password = 
database.default.DBDriver = SQLite3
database.default.DBPath = WRITEPATH/rh
database.default.DBPrefix = 
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci
database.default.swapPre = 
database.default.encrypt = false
database.default.compress = false
database.default.strictOn = false
database.default.failover = []
database.default.ssl = []

# logging
log.threshold = 4
log.dateFormat = 'Y-m-d H:i:s'
log.handlers = [CodeIgniter\Log\Handlers\File::class]
log.file.permissions = 0644

# security
security.tokenName = 'ci_token'
security.headerName = 'X-CSRF-TOKEN'
security.cookieName = 'XSRF-TOKEN'
security.expires = 7200
security.regenerate = true
security.redirect = true
security.samesite = 'Lax'

# toolbar
toolbar.collectors[] = CodeIgniter\Toolbar\Collectors\Timers::class
toolbar.collectors[] = CodeIgniter\Toolbar\Collectors\Database::class
toolbar.collectors[] = CodeIgniter\Toolbar\Collectors\Logs::class
toolbar.collectors[] = CodeIgniter\Toolbar\Collectors\Views::class
toolbar.collectors[] = CodeIgniter\Toolbar\Collectors\Cache::class
toolbar.collectors[] = CodeIgniter\Toolbar\Collectors\Files::class
toolbar.collectors[] = CodeIgniter\Toolbar\Collectors\Routes::class
toolbar.collectors[] = CodeIgniter\Toolbar\Collectors\Events::class
